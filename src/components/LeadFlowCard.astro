---
---

<div class="lfc-card card">
  <h3 class="lfc-title">Lead Response Flow</h3>

  <ul class="lfc-rows" role="list">
    <!-- Row 1: New inquiry -->
    <li class="lfc-row fade-up" style="animation-delay: 0.1s">
      <span class="lfc-time">2:47 a.m.</span>
      <div class="lfc-content">
        <div class="lfc-indicator lfc-dot" aria-hidden="true"></div>
        <div>
          <p class="lfc-status"><strong>New inquiry comes in</strong></p>
          <p class="lfc-sub">Contact form submitted from website</p>
        </div>
      </div>
    </li>

    <!-- Row 2: Response sent -->
    <li class="lfc-row fade-up" style="animation-delay: 0.25s">
      <span class="lfc-time">2:48 a.m.</span>
      <div class="lfc-content">
        <div class="lfc-indicator lfc-check" aria-hidden="true">
          <svg width="12" height="10" viewBox="0 0 12 10" fill="none" aria-hidden="true">
            <path d="M1 5L4.5 8.5L11 1.5" stroke="#F2F2F0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <p class="lfc-status"><strong>Response sent</strong></p>
          <p class="lfc-sub">Initial acknowledgment delivered</p>
        </div>
      </div>
    </li>

    <!-- Row 3: Lead details captured -->
    <li class="lfc-row fade-up" style="animation-delay: 0.4s">
      <span class="lfc-time">2:50 a.m.</span>
      <div class="lfc-content">
        <div class="lfc-indicator lfc-check" aria-hidden="true">
          <svg width="12" height="10" viewBox="0 0 12 10" fill="none" aria-hidden="true">
            <path d="M1 5L4.5 8.5L11 1.5" stroke="#F2F2F0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <p class="lfc-status"><strong>Lead details captured</strong></p>
          <p class="lfc-sub">Contact info, timing, and needs documented</p>
        </div>
      </div>
    </li>

    <!-- Row 4: Appointment ready — highlighted -->
    <li class="lfc-row lfc-row--complete fade-up" style="animation-delay: 0.55s">
      <span class="lfc-time">8:00 a.m.</span>
      <div class="lfc-content">
        <div class="lfc-indicator lfc-check" aria-hidden="true">
          <svg width="12" height="10" viewBox="0 0 12 10" fill="none" aria-hidden="true">
            <path d="M1 5L4.5 8.5L11 1.5" stroke="#F2F2F0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <p class="lfc-status"><strong>Appointment ready for review</strong></p>
          <p class="lfc-sub">Qualified lead prepared for your team's follow-up</p>
        </div>
      </div>
    </li>
  </ul>
</div>

<style>
  .lfc-card {
    padding: 2rem 1.75rem;
    max-width: 500px;
    width: 100%;
  }

  .lfc-title {
    font-size: 17px;
    font-weight: 700;
    color: #0B0D09;
    margin: 0 0 1.5rem;
    text-align: center;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  .lfc-rows {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .lfc-row {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem 1rem;
    border-radius: 10px;
    margin-bottom: 0.375rem;
    background: transparent;
  }

  .lfc-row--complete {
    background: rgba(27, 97, 25, 0.07);
  }

  .lfc-time {
    font-size: 12px;
    font-weight: 500;
    color: #1b6119;
    min-width: 68px;
    flex-shrink: 0;
    padding-top: 2px;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  .lfc-content {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    flex: 1;
  }

  .lfc-indicator {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    margin-top: 1px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lfc-dot {
    background: #1b6119;
    position: relative;
  }

  .lfc-dot::after {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #F2F2F0;
    position: absolute;
  }

  .lfc-check {
    background: #1b6119;
  }

  .lfc-status {
    margin: 0;
    font-size: 14px;
    color: #0B0D09;
    line-height: 1.3;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  .lfc-sub {
    margin: 0.2rem 0 0;
    font-size: 12.5px;
    color: #5B5E57;
    line-height: 1.4;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }
</style>
