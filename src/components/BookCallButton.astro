---
interface Props {
  showCta?: boolean;
  class?: string;
}
const { showCta = true, class: className = '' } = Astro.props;
---

{showCta && (
  <a
    href="#"
    class:list={['book-call-btn', className]}
    aria-label="Book a 15-minute call with MannaFlow"
  >
    Book a 15-minute call
  </a>
)}

<style>
  .book-call-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1.375rem;
    background-color: #1b6119;
    color: #E9E9E9;
    font-size: 15px;
    font-weight: 600;
    border-radius: 14px;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 150ms ease, transform 150ms ease;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  .book-call-btn:hover {
    background-color: #3a4034;
    transform: translateY(-1px);
  }

  .book-call-btn:active {
    transform: translateY(0);
  }
</style>
