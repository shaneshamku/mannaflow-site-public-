---

<section id="who-its-built-for" class="who-section section-large" aria-labelledby="who-heading">
  <div class="content-wrap who-inner">
    <!-- Left: intro -->
    <div class="who-intro">
      <p class="eyebrow who-eyebrow">Built for HVAC</p>
      <h2 class="heading-2" id="who-heading">Built for how HVAC shops actually run</h2>
      <p class="subhead who-subhead">
        For 5–30 tech contractors already getting leads — and losing jobs to slow replies, missed calls,
        and manual follow-up. MannaFlow turns the demand you already have into booked revenue.
      </p>
    </div>

    <!-- Right: benefit grid -->
    <ul class="who-grid" role="list">
      {benefits.map((b) => (
        <li class="who-item" role="listitem">
          <div class="who-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1b6119" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d={b.iconPath} />
            </svg>
          </div>
          <div class="who-item-text">
            <h3 class="who-item-title">{b.title}</h3>
            <p class="who-item-desc">{b.desc}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .who-section {
    background: transparent;
  }

  .who-inner {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 4rem;
    align-items: start;
  }

  .who-intro .eyebrow {
    background: transparent;
    padding: 0;
    color: #1b6119;
    display: block;
    margin-bottom: 1rem;
  }

  .who-subhead {
    margin: 1.25rem 0 0;
    max-width: 420px;
  }

  /* Benefit grid */
  .who-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem 2.5rem;
  }

  .who-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .who-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    background: #FFFFFF;
    border: 1px solid #D7D7D3;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .who-item-title {
    margin: 0 0 0.4rem;
    font-size: 16px;
    font-weight: 700;
    color: #0B0D09;
    line-height: 1.3;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  .who-item-desc {
    margin: 0;
    font-size: 14.5px;
    line-height: 1.55;
    color: #5B5E57;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  @media (max-width: 900px) {
    .who-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .who-subhead {
      max-width: 100%;
    }
  }

  @media (max-width: 560px) {
    .who-grid {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
  }
</style>
