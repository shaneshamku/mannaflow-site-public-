---
import { valueTabs } from '../data/value-tabs';
import LeadFlowCard from './LeadFlowCard.astro';

// Per-card accent colors (echoes the multi-accent inspiration)
const accents = ['#1b6119', '#0C91ED', '#3a4034', '#719294'];
---

<section id="value" class="value-tabs-section section-large">
  <div class="content-wrap">
    <!-- Intro (flush under the hero) -->
    <div class="vt-intro">
      <p class="eyebrow">The Problem Worth Solving</p>
      <h2 class="heading-2">The Gap Isn't Demand. It's Response Time</h2>
      <p class="subhead vt-subhead">
        The leads are there. The gap is what happens after they arrive.
      </p>
    </div>

    <!-- Card grid -->
    <ul class="vt-grid" role="list">
      {valueTabs.map((tab, i) => (
        <li class="vt-card card hover-lift" style={`--accent: ${accents[i % accents.length]}`}>
          <span class="vt-accent-bar" aria-hidden="true"></span>
          <div class="vt-card-head">
            <div class="vt-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d={tab.iconPath} />
              </svg>
            </div>
            <span class="vt-chip">{tab.label}</span>
          </div>
          <h3 class="vt-benefit">{tab.benefit}</h3>
          <p class="body-text vt-supporting">{tab.supportingText}</p>
        </li>
      ))}
    </ul>

    <!-- LeadFlowCard preview below the grid -->
    <div class="vt-card-preview">
      <LeadFlowCard />
    </div>
  </div>
</section>

<style>
  .value-tabs-section {
    /* transparent: inherits body base #E9E9E9 */
    background: transparent;
    /* Tighten the seam with the hero (which trims its own bottom padding) */
    padding-top: clamp(1.5rem, 3vw, 2.5rem);
  }

  .vt-intro {
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
    margin-bottom: 3.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .vt-intro .eyebrow {
    background: transparent;
    padding: 0;
    color: #1b6119;
  }

  .vt-subhead {
    margin: 0;
  }

  /* Card grid */
  .vt-grid {
    list-style: none;
    margin: 0 0 3.5rem;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .vt-card {
    position: relative;
    overflow: hidden;
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  /* Colored top accent bar */
  .vt-accent-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--accent);
  }

  .vt-card-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .vt-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    background: var(--accent);
    border-radius: 11px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .vt-chip {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    padding: 0.3rem 0.6rem;
    border-radius: 9999px;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  .vt-benefit {
    margin: 0;
    font-size: 18px;
    font-weight: 700;
    color: #0B0D09;
    line-height: 1.3;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  .vt-supporting {
    margin: 0;
    font-size: 14.5px;
    line-height: 1.55;
  }

  /* LeadFlowCard wrapper */
  .vt-card-preview {
    display: flex;
    justify-content: center;
  }

  @media (max-width: 900px) {
    .vt-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 540px) {
    .vt-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
