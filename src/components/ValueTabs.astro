---
import { valueTabs } from '../data/value-tabs';
---

<section id="value" class="value-tabs-section section-large">
  <div class="content-wrap">
    <!-- Intro -->
    <div class="vt-intro">
      <p class="eyebrow">The Problem Worth Solving</p>
      <h2 class="heading-2">The Gap Isn't Demand. It's Response Time</h2>
      <p class="subhead vt-subhead">
        The leads are there. The gap is what happens after they arrive.
      </p>
    </div>

    <!-- Tab widget -->
    <div class="vt-widget">
      <!-- Tab list -->
      <div role="tablist" aria-label="Value areas" class="vt-tablist">
        {valueTabs.map((tab, i) => (
          <button
            role="tab"
            id={`tab-${tab.id}`}
            aria-controls={`panel-${tab.id}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            tabindex={i === 0 ? 0 : -1}
            class:list={['vt-tab', i === 0 ? 'vt-tab--active' : '']}
            data-tab-id={tab.id}
          >
            {tab.label}
          </button>
        ))}
      </div>

      <!-- Tab panels -->
      <div class="vt-panels">
        {valueTabs.map((tab, i) => (
          <div
            role="tabpanel"
            id={`panel-${tab.id}`}
            aria-labelledby={`tab-${tab.id}`}
            class:list={['vt-panel', i === 0 ? 'vt-panel--active' : '']}
            hidden={i !== 0}
          >
            <div class="vt-panel-inner">
              <!-- Icon -->
              <div class="vt-icon" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#FAF7EF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d={tab.iconPath} />
                </svg>
              </div>
              <!-- Content -->
              <div class="vt-panel-content">
                <p class="vt-benefit">{tab.benefit}</p>
                <p class="body-text vt-supporting">{tab.supportingText}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .value-tabs-section {
    /* transparent: inherits body valley-floor #EEECE1, lets the river show in gutters */
    background: transparent;
  }

  .vt-intro {
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
    margin-bottom: 3.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .vt-intro .eyebrow {
    background: transparent;
    padding: 0;
    color: #54a563;
  }

  .vt-subhead {
    margin: 0;
  }

  .vt-widget {
    max-width: 860px;
    margin-inline: auto;
  }

  /* Tab list */
  .vt-tablist {
    display: flex;
    gap: 0.5rem;
    border-bottom: 2px solid #E2D5C4;
    overflow-x: auto;
    scrollbar-width: none;
    padding-bottom: 0;
    margin-bottom: 0;
  }

  .vt-tablist::-webkit-scrollbar {
    display: none;
  }

  .vt-tab {
    flex-shrink: 0;
    padding: 0.75rem 1.25rem;
    font-size: 15px;
    font-weight: 600;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    color: #4A4A4A;
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    cursor: pointer;
    border-radius: 8px 8px 0 0;
    transition: color 150ms ease, border-color 150ms ease, background 150ms ease;
    white-space: nowrap;
  }

  .vt-tab:hover {
    color: #1C1C1C;
    background: rgba(84, 165, 99, 0.08);
  }

  .vt-tab--active {
    color: #54a563;
    border-bottom-color: #54a563;
    background: rgba(84, 165, 99, 0.08);
  }

  /* Panels */
  .vt-panel {
    display: none;
  }

  .vt-panel--active {
    display: block;
  }

  .vt-panel-inner {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
    padding: 2.5rem 2rem;
    background: rgba(12, 145, 237, 0.05);
    border-radius: 0 0 14px 14px;
    border: 1px solid #E2D5C4;
    border-top: none;
  }

  .vt-icon {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    background: #54a563;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .vt-panel-content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .vt-benefit {
    margin: 0;
    font-size: 22px;
    font-weight: 700;
    color: #1C1C1C;
    line-height: 1.3;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  .vt-supporting {
    margin: 0;
    max-width: 580px;
  }

  @media (max-width: 600px) {
    .vt-panel-inner {
      flex-direction: column;
      gap: 1.25rem;
      padding: 1.75rem 1.25rem;
    }

    .vt-tab {
      padding: 0.625rem 1rem;
      font-size: 14px;
    }
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('[role="tab"]');
  const panels = document.querySelectorAll<HTMLElement>('[role="tabpanel"]');

  function activateTab(tab: HTMLButtonElement) {
    // Deactivate all
    tabs.forEach(t => {
      t.setAttribute('aria-selected', 'false');
      t.setAttribute('tabindex', '-1');
      t.classList.remove('vt-tab--active');
    });
    panels.forEach(p => {
      p.hidden = true;
      p.classList.remove('vt-panel--active');
    });

    // Activate selected
    tab.setAttribute('aria-selected', 'true');
    tab.setAttribute('tabindex', '0');
    tab.classList.add('vt-tab--active');

    const panelId = tab.getAttribute('aria-controls')!;
    const panel = document.getElementById(panelId)!;
    panel.hidden = false;
    panel.classList.add('vt-panel--active');
  }

  tabs.forEach((tab, index) => {
    tab.addEventListener('click', () => activateTab(tab));

    tab.addEventListener('keydown', (e: KeyboardEvent) => {
      const tabArray = Array.from(tabs);
      let newIndex = index;

      if (e.key === 'ArrowRight') {
        newIndex = (index + 1) % tabs.length;
      } else if (e.key === 'ArrowLeft') {
        newIndex = (index - 1 + tabs.length) % tabs.length;
      } else if (e.key === 'Home') {
        newIndex = 0;
      } else if (e.key === 'End') {
        newIndex = tabs.length - 1;
      } else {
        return;
      }

      e.preventDefault();
      activateTab(tabArray[newIndex]);
      tabArray[newIndex].focus();
    });
  });
</script>
