---
---

<section class="demo-section section-compact" aria-label="Demo preview">
  <div class="content-wrap">
    <div class="demo-card card">
      <div class="demo-inner">
        <div class="demo-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1b6119" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="5 3 19 12 5 21 5 3"></polygon>
          </svg>
        </div>
        <div class="demo-content">
          <h2 class="demo-title">Preview The Booking Flow</h2>
          <p class="demo-copy">
            This slot becomes a live, market-specific demo once each industry page is ready.
          </p>
          <p class="demo-small">
            Coming versions: service-business intake, broker-style lead qualification, and more.
          </p>
          <a href="#" class="demo-cta" aria-label="Open demo preview (coming soon)">
            Open demo preview
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .demo-section {
    /* transparent: inherits body valley-floor #E9E9E9, lets the river show in gutters */
    background: transparent;
  }

  .demo-card {
    background: rgba(27, 97, 25, 0.06);
    border-color: rgba(27, 97, 25, 0.15);
    box-shadow: 0 16px 48px rgba(27, 97, 25, 0.1);
    max-width: 720px;
    margin-inline: auto;
  }

  .demo-inner {
    padding: 2.5rem 2.25rem;
    display: flex;
    align-items: flex-start;
    gap: 1.75rem;
  }

  .demo-icon {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    background: rgba(27, 97, 25, 0.1);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .demo-content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .demo-title {
    margin: 0;
    font-size: 22px;
    font-weight: 700;
    color: #0B0D09;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  .demo-copy {
    margin: 0;
    font-size: 16px;
    color: #5B5E57;
    line-height: 1.55;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  .demo-small {
    margin: 0;
    font-size: 13.5px;
    color: #5B5E57;
    line-height: 1.5;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  .demo-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
    padding: 0.625rem 1.25rem;
    background: #1b6119;
    color: #E9E9E9;
    font-size: 15px;
    font-weight: 600;
    border-radius: 14px;
    text-decoration: none;
    align-self: flex-start;
    transition: background 150ms ease, transform 150ms ease;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  .demo-cta:hover {
    background: #3a4034;
    transform: translateY(-1px);
  }

  @media (max-width: 600px) {
    .demo-inner {
      flex-direction: column;
      gap: 1.25rem;
      padding: 2rem 1.5rem;
    }
  }
</style>
