---
// Sample placeholder logos. Swap each `iconPath`/`name` for a real <img> logo later.
const logos = [
  { name: 'Make', iconPath: 'M3 3h7v7H3zM14 3h7v7h-7zM3 14h7v7H3zM14 14h7v7h-7z' },
  { name: 'Retell', iconPath: 'M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3zM19 10v2a7 7 0 01-14 0v-2M12 19v4M8 23h8' },
  { name: 'Twilio', iconPath: 'M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z' },
  { name: 'HubSpot', iconPath: 'M12 2a10 10 0 100 20 10 10 0 000-20zM12 8v8M8 12h8' },
  { name: 'Calendly', iconPath: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
];

// Repeat the logo set enough times that a single "half" is always wider than
// the viewport, then duplicate that half. translateX(-50%) then advances by
// exactly one half-width, so a chip leaving the left re-enters on the right
// with no blank gap (even on wide screens with only a few logos).
const baseSet = [...logos, ...logos, ...logos];
const track = [...baseSet, ...baseSet];
---

<section id="integrations" class="integrations-section section-compact" aria-labelledby="integrations-heading">
  <div class="content-wrap">
    <h2 class="heading-2 integrations-heading" id="integrations-heading">Integrations</h2>
    <p class="subhead integrations-subhead">Works with the tools your business already runs on.</p>
  </div>

  <div class="marquee" role="presentation">
    <ul class="marquee-track" role="list">
      {track.map((logo, i) => (
        <li class="logo-chip" aria-hidden={i >= baseSet.length ? 'true' : undefined}>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1b6119" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d={logo.iconPath} />
          </svg>
          <span class="logo-name">{logo.name}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .integrations-section {
    background: transparent;
    overflow: hidden;
  }

  .integrations-heading {
    text-align: center;
  }

  .integrations-subhead {
    text-align: center;
    margin: 1rem auto 2.5rem;
    max-width: 520px;
  }

  /* Marquee */
  .marquee {
    width: 100%;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent, #000 12%, #000 88%, transparent);
    mask-image: linear-gradient(to right, transparent, #000 12%, #000 88%, transparent);
  }

  .marquee-track {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    width: max-content;
    gap: 1.25rem;
    animation: marquee-scroll 28s linear infinite;
  }

  .marquee:hover .marquee-track {
    animation-play-state: paused;
  }

  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .logo-chip {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.9rem 1.5rem;
    background: #FFFFFF;
    border: 1px solid #D7D7D3;
    border-radius: 12px;
    box-shadow: 0 8px 24px rgba(20, 22, 18, 0.06);
  }

  .logo-name {
    font-size: 16px;
    font-weight: 700;
    color: #0B0D09;
    letter-spacing: -0.01em;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee {
      -webkit-mask-image: none;
      mask-image: none;
      overflow-x: auto;
    }
    .marquee-track {
      animation: none;
      width: 100%;
      justify-content: center;
      flex-wrap: wrap;
      gap: 1rem;
    }
    /* Hide the duplicate set when static */
    .logo-chip[aria-hidden='true'] {
      display: none;
    }
  }
</style>
