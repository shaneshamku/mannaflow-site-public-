---
const features = [
  {
    title: 'Missed Inquiry Recovery',
    desc: 'Help capture leads that would otherwise sit unanswered.',
    iconPath: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Speed-To-Lead Support',
    desc: 'Shorten the time between interest and response.',
    iconPath: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
  },
  {
    title: 'Lead Qualification',
    desc: 'Capture the details that matter before your team follows up.',
    iconPath: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4',
  },
  {
    title: 'Booking Handoff',
    desc: 'Move qualified prospects toward a clear next step.',
    iconPath: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
  },
  {
    title: 'Follow-Up Support',
    desc: 'Keep open opportunities from going cold.',
    iconPath: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
  },
  {
    title: 'Owner Visibility',
    desc: 'See where leads are coming from and what happened next.',
    iconPath: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z',
  },
];
---

<section id="features" class="features-section section-compact" aria-labelledby="features-heading">
  <div class="content-wrap">
    <h2 class="heading-2 features-heading" id="features-heading">
      Built Around The Moments Where Leads Usually Fall Through
    </h2>

    <ul class="features-grid" role="list">
      {features.map(f => (
        <li class="feature-card card-paper hover-lift" role="listitem">
          <div class="feature-icon-wrap" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#54a563" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d={f.iconPath} />
            </svg>
          </div>
          <h3 class="feature-title">{f.title}</h3>
          <p class="feature-desc">{f.desc}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .features-section {
    /* transparent: inherits body valley-floor #EEECE1, lets the river show in gutters */
    background: transparent;
  }

  .features-heading {
    text-align: left;
    margin-bottom: 2.5rem;
    max-width: 600px;
  }

  .features-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .feature-card {
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    cursor: default;
    transition: transform 150ms ease, box-shadow 150ms ease, border-color 150ms ease;
  }

  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(61, 43, 31, 0.1);
    border-color: rgba(63, 111, 78, 0.25);
  }

  .feature-icon-wrap {
    width: 40px;
    height: 40px;
    background: #FFFFFF;
    border-radius: 10px;
    border: 1px solid #E2D5C4;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .feature-title {
    margin: 0;
    font-size: 17px;
    font-weight: 700;
    color: #1C1C1C;
    line-height: 1.3;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  .feature-desc {
    margin: 0;
    font-size: 14.5px;
    color: #4A4A4A;
    line-height: 1.55;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  @media (max-width: 900px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .features-grid {
      grid-template-columns: 1fr;
    }

    .features-heading {
      text-align: center;
      max-width: 100%;
    }
  }
</style>
